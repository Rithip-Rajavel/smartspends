    "components": {
        "schemas": {
            "IncomeRequestDTO": {
                "required": [
                    "amount",
                    "month",
                    "source",
                    "year"
                ],
                "type": "object",
                "properties": {
                    "amount": {
                        "type": "number"
                    },
                    "source": {
                        "type": "string"
                    },
                    "month": {
                        "maximum": 12,
                        "minimum": 1,
                        "type": "integer",
                        "format": "int32"
                    },
                    "year": {
                        "minimum": 2000,
                        "type": "integer",
                        "format": "int32"
                    },
                    "description": {
                        "type": "string"
                    }
                }
            },
            "ExpenseRequestDTO": {
                "required": [
                    "amount",
                    "category",
                    "paymentMode"
                ],
                "type": "object",
                "properties": {
                    "amount": {
                        "type": "number"
                    },
                    "category": {
                        "type": "string",
                        "enum": [
                            "FOOD",
                            "TRANSPORT",
                            "ENTERTAINMENT",
                            "BILLS",
                            "SHOPPING",
                            "HEALTHCARE",
                            "MISCELLANEOUS"
                        ]
                    },
                    "paymentMode": {
                        "type": "string",
                        "enum": [
                            "CASH",
                            "CARD",
                            "UPI",
                            "NET_BANKING",
                            "OTHER"
                        ]
                    },
                    "description": {
                        "type": "string"
                    }
                }
            },
            "RegistrationRequestDTO": {
                "required": [
                    "mobileNumber",
                    "password",
                    "username"
                ],
                "type": "object",
                "properties": {
                    "username": {
                        "maxLength": 50,
                        "minLength": 3,
                        "type": "string"
                    },
                    "password": {
                        "maxLength": 2147483647,
                        "minLength": 6,
                        "type": "string"
                    },
                    "mobileNumber": {
                        "pattern": "^[0-9]{10}$",
                        "type": "string"
                    },
                    "email": {
                        "type": "string"
                    }
                }
            },
            "LoginRequestDTO": {
                "required": [
                    "mobileNumber",
                    "password"
                ],
                "type": "object",
                "properties": {
                    "mobileNumber": {
                        "type": "string"
                    },
                    "password": {
                        "type": "string"
                    }
                }
            }
        },
        "securitySchemes": {
            "Bearer Token": {
                "type": "http",
                "description": "JWT token for API authentication",
                "scheme": "bearer",
                "bearerFormat": "JWT"
            }
        }
    }
